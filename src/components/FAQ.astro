---
import type { FAQItem } from '../data/tarotReadings';
const { faqs, title = '자주 묻는 질문' } = Astro.props as { faqs: FAQItem[]; title?: string };
---
<section class="content-section faq-section">
  <h2>{title}</h2>
  <div class="faq-list">
    {faqs.map((faq) => (
      <details>
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </div>
</section>
