---
import type { TarotReadingPage } from '../data/tarotReadings';
const { reading } = Astro.props as { reading: TarotReadingPage };
---
<article class="feature-card">
  <span class="eyebrow">{reading.shortTitle}</span>
  <h3>{reading.title.split('|')[0].trim()}</h3>
  <p>{reading.summary}</p>
  <a class="card-link" href={`/tarot/${reading.slug}/`}>{reading.shortTitle} 보기 →</a>
</article>
