---
import { dedupeRepeatedLabel, type BreadcrumbItem } from '../data/site';
const { items = [] } = Astro.props as { items: BreadcrumbItem[] };
---
{items.length > 0 && (
  <nav class="breadcrumb container" aria-label="현재 위치">
    {items.map((item, index) => (
      <>
        {index > 0 && <span aria-hidden="true">/</span>}
        {index === items.length - 1 ? <span aria-current="page">{dedupeRepeatedLabel(item.name)}</span> : <a href={item.path}>{dedupeRepeatedLabel(item.name)}</a>}
      </>
    ))}
  </nav>
)}
