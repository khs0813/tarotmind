---
import Layout from '../../components/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AdSlot from '../../components/AdSlot.astro';
import FAQ from '../../components/FAQ.astro';
import TarotReader from '../../components/TarotReader.astro';
import RelatedReadings from '../../components/RelatedReadings.astro';
import { tarotReadings, type TarotReadingPage } from '../../data/tarotReadings';
import { DEFAULT_LASTMOD, DEFAULT_OG_IMAGE, SITE_NAME, getSiteUrl } from '../../data/site';

export function getStaticPaths() {
  return tarotReadings.map((reading) => ({ params: { slug: reading.slug }, props: { reading } }));
}

const { reading } = Astro.props as { reading: TarotReadingPage };
const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/tarot/${reading.slug}/`;
const imageUrl = new URL(DEFAULT_OG_IMAGE, `${siteUrl}/`).toString();
const breadcrumbs = [
  { name: '타로마음', path: '/' },
  { name: '타로 리딩', path: '/tarot/' },
  { name: reading.shortTitle, path: `/tarot/${reading.slug}/` }
];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@id': `${pageUrl}#application`,
    '@type': 'WebApplication',
    name: reading.title.split('|')[0].trim(),
    applicationCategory: 'LifestyleApplication',
    operatingSystem: 'Web',
    url: pageUrl,
    description: reading.description,
    inLanguage: 'ko-KR',
    isAccessibleForFree: true,
    keywords: reading.targetKeywords.join(', '),
    dateModified: DEFAULT_LASTMOD,
    image: imageUrl,
    mainEntityOfPage: pageUrl,
    publisher: { '@type': 'Organization', name: SITE_NAME },
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW', availability: 'https://schema.org/InStock' }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: reading.faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer }
    }))
  }
];
---
<Layout
  title={reading.title}
  description={reading.description}
  canonicalPath={`/tarot/${reading.slug}/`}
  keywords={reading.targetKeywords}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
  datePublished={DEFAULT_LASTMOD}
  dateModified={DEFAULT_LASTMOD}
>
  <Breadcrumbs items={breadcrumbs} />
  <section class="page-hero container tarot-page-hero">
    <span class="eyebrow">{reading.shortTitle}</span>
    <h1>{reading.title.split('|')[0].trim()}</h1>
    <p>{reading.description}</p>
    <div class="keyword-chips">
      {reading.targetKeywords.map((keyword) => <span>{keyword}</span>)}
    </div>
  </section>

  <AdSlot position="top" />

  <div class="container">
    <TarotReader reading={reading} />
  </div>

  <AdSlot position="middle" />

  <article class="container readable-content">
    <section class="content-section">
      <h2>{reading.shortTitle} 사용법</h2>
      <p>{reading.intro}</p>
      <p>카드를 뽑기 전에는 질문을 너무 복잡하게 만들지 말고, 지금 가장 궁금한 한 가지 흐름을 떠올리는 것이 좋습니다. 결과는 확정적인 예언이 아니라 생각을 정리하는 참고 문장으로 활용하세요.</p>
    </section>
    {reading.sections.map((section) => (
      <section class="content-section">
        <h2>{section.title}</h2>
        <p>{section.content}</p>
      </section>
    ))}
    <section class="content-section warning-box">
      <h2>결과를 볼 때 주의할 점</h2>
      <p>본 타로 리딩은 오락 및 참고용 콘텐츠입니다. 중요한 건강, 법률, 투자, 금전, 인간관계 결정은 전문가와 상담하거나 현실적인 정보를 함께 확인하시기 바랍니다.</p>
      {reading.category === 'money' && <p>금전운 타로 결과는 투자 조언이 아니며 특정 금융상품이나 종목의 매수·매도를 권유하지 않습니다.</p>}
      {reading.category === 'career' && <p>퇴사, 이직, 계약 등 중요한 결정은 실제 조건과 전문가 조언을 함께 고려하세요.</p>}
    </section>
    <FAQ faqs={reading.faqs} />
    <RelatedReadings slugs={reading.relatedSlugs} />
  </article>

  <AdSlot position="bottom" />
</Layout>
