---
import Layout from '../components/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import FAQ from '../components/FAQ.astro';
import ReadingCard from '../components/ReadingCard.astro';
import { tarotReadings } from '../data/tarotReadings';
import { guides } from '../data/guides';
import { DEFAULT_LASTMOD, getSiteUrl, SITE_DESCRIPTION, SITE_NAME } from '../data/site';

const siteUrl = getSiteUrl();
const faqs = [
  { question: '타로마음은 진짜 AI API를 사용하나요?', answer: 'MVP에서는 외부 AI API를 사용하지 않고, 78장 타로 카드 데이터와 해석 템플릿을 조합해 AI 스타일 문장으로 리딩 결과를 생성합니다.' },
  { question: '리딩 결과가 서버에 저장되나요?', answer: '아니요. 리딩 결과는 서버에 저장되지 않습니다. 최근 리딩 저장을 선택한 경우에만 현재 브라우저에 저장됩니다.' },
  { question: '타로 결과를 중요한 결정에 사용해도 되나요?', answer: '본 콘텐츠는 오락 및 참고용입니다. 건강, 법률, 투자, 금전, 인간관계의 중대한 결정은 전문가 조언과 현실적인 정보를 함께 확인하세요.' }
];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: '무료 AI 스타일 타로 리딩 목록',
    itemListElement: tarotReadings.map((reading, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: reading.shortTitle,
      url: `${siteUrl}/tarot/${reading.slug}/`
    }))
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer }
    }))
  }
];
---
<Layout
  title={`${SITE_NAME} | 무료 AI 타로 리딩`}
  description={SITE_DESCRIPTION}
  canonicalPath="/"
  keywords={['무료 타로', 'AI 스타일 타로', '오늘의 타로', '연애 타로', '재회 타로', '직장운 타로', '금전운 타로']}
  jsonLd={jsonLd}
  datePublished={DEFAULT_LASTMOD}
  dateModified={DEFAULT_LASTMOD}
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">무료 AI 스타일 타로 리딩</span>
        <h1>무료 AI 스타일 타로 리딩<br />오늘의 타로부터 연애·재회·금전운까지</h1>
        <p>카드를 고르면 오늘의 메시지가 펼쳐집니다. 서버 저장 없이 브라우저에서 가볍게 리딩을 확인하세요.</p>
        <div class="hero-actions">
          <a class="primary-button" href="/tarot/today/">오늘의 타로 시작</a>
          <a class="secondary-button" href="/tarot/">타로 전체 보기</a>
        </div>
      </div>
      <div class="hero-card-stack" aria-hidden="true">
        <div class="hero-tarot-card">✦</div>
        <div class="hero-tarot-card hero-tarot-card-alt">☾</div>
      </div>
    </div>
  </section>
  <section class="container content-section popular-readings">
    <div class="section-heading">
      <span class="eyebrow">인기 리딩</span>
      <h2>상황별 무료 타로 리딩</h2>
      <p>카드를 바로 뽑을 수 있고, 최근 리딩 저장은 사용자가 선택한 경우에만 브라우저에 저장됩니다.</p>
    </div>
    <div class="card-grid-list">
      {tarotReadings.map((reading) => <ReadingCard reading={reading} />)}
    </div>
  </section>

  <AdSlot placement="home" />

  <section class="container content-section two-column-section">
    <div class="info-card">
      <h2>타로 카드 의미를 알고 싶다면</h2>
      <p>메이저 아르카나와 마이너 아르카나의 기본 키워드, 정방향·역방향 해석을 한 페이지에서 확인할 수 있습니다.</p>
      <a class="text-link" href="/cards/">타로 카드 의미 보기 →</a>
    </div>
    <div class="info-card">
      <h2>초보자를 위한 타로 가이드</h2>
      <p>타로 보는 법, 질문 정하는 방법, 1장·3장 스프레드의 차이를 쉽게 정리했습니다.</p>
      <a class="text-link" href="/guides/">가이드 모음 보기 →</a>
    </div>
  </section>
  <section class="container content-section">
    <div class="section-heading">
      <span class="eyebrow">타로 가이드</span>
      <h2>타로를 더 잘 이해하는 글</h2>
    </div>
    <div class="card-grid-list">
      {guides.slice(0, 4).map((guide) => (
        <article class="feature-card">
          <span class="eyebrow">가이드</span>
          <h3>{guide.title.split('|')[0].trim()}</h3>
          <p>{guide.description}</p>
          <a class="card-link" href={`/guides/${guide.slug}/`}>{guide.title.split('|')[0].trim()} 보기 →</a>
        </article>
      ))}
    </div>
  </section>

  <section class="container">
    <FAQ faqs={faqs} />
  </section>
</Layout>
