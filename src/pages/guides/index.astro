---
import Layout from '../../components/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { guides } from '../../data/guides';
import { DEFAULT_LASTMOD, getSiteUrl } from '../../data/site';
const breadcrumbs = [{ name: '타로마음', path: '/' }, { name: '타로 가이드', path: '/guides/' }];
const siteUrl = getSiteUrl();
const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '타로 가이드 모음',
  itemListElement: guides.map((guide, index) => ({ '@type': 'ListItem', position: index + 1, name: guide.title, url: `${siteUrl}/guides/${guide.slug}/` }))
}];
---
<Layout
  title="타로 가이드 | 타로 보는 법과 질문 예시 모음"
  description="타로 초보자를 위한 카드 해석 방법, 질문하는 법, 스프레드 활용법, 연애·재회·금전운 타로 팁을 확인하세요."
  canonicalPath="/guides/"
  pageType="CollectionPage"
  keywords={['타로 가이드', '타로 카드 의미', '타로 보는 법', '메이저 아르카나', '타로 스프레드']}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
  datePublished={DEFAULT_LASTMOD}
  dateModified={DEFAULT_LASTMOD}
>
  <Breadcrumbs items={breadcrumbs} />
  <section class="page-hero container">
    <span class="eyebrow">타로 가이드</span>
    <h1>타로 보는 법과 질문 예시 가이드</h1>
    <p>카드 해석 방법, 질문 정리, 스프레드 활용법을 익히고 오늘의 타로와 연애·재회·금전운 리딩에 활용해 보세요.</p>
  </section>
  <section class="container content-section">
    <div class="card-grid-list">
      {guides.map((guide) => (
        <article class="feature-card">
          <span class="eyebrow">가이드</span>
          <h3>{guide.title.split('|')[0].trim()}</h3>
          <p>{guide.description}</p>
          <a class="card-link" href={`/guides/${guide.slug}/`}>{guide.title.split('|')[0].trim()} 보기 →</a>
        </article>
      ))}
    </div>
  </section>
</Layout>
