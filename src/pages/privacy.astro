---
import Layout from '../components/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getContactEmail } from '../data/site';
const breadcrumbs = [{ name: '타로마음', path: '/' }, { name: '개인정보처리방침', path: '/privacy/' }];
const email = getContactEmail();
---
<Layout title="개인정보처리방침 | 타로마음" description="타로마음의 개인정보 처리 기준, localStorage 저장 방식, 카카오 애드핏 광고 관련 안내를 확인할 수 있습니다." canonicalPath="/privacy/" breadcrumbs={breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />
  <article class="container readable-content page-hero">
    <span class="eyebrow">개인정보</span>
    <h1>개인정보처리방침</h1>
    <section class="content-section">
      <h2>회원가입과 서버 저장</h2>
      <p>타로마음은 회원가입, 로그인, 댓글, 게시판 기능을 제공하지 않습니다. 타로 결과는 서버 DB에 저장하지 않습니다.</p>
    </section>
    <section class="content-section">
      <h2>브라우저 저장소 사용</h2>
      <p>사용자가 “이 브라우저에 최근 리딩 저장하기”를 선택한 경우에만 리딩 결과가 현재 브라우저의 localStorage에 저장될 수 있습니다. 공용 PC에서는 저장 기능 사용을 권장하지 않습니다.</p>
    </section>
    <section class="content-section">
      <h2>광고 안내</h2>
      <p>이 사이트는 카카오 애드핏 광고 영역을 포함할 수 있으며, 광고 노출 과정에서 쿠키 또는 접속 정보가 처리될 수 있습니다. Google AdSense와 제휴 상품 영역은 사용하지 않습니다.</p>
    </section>
    <section class="content-section">
      <h2>문의</h2>
      <p>개인정보 관련 문의는 <a href={`mailto:${email}`}>{email}</a>로 보내주세요.</p>
    </section>
  </article>
</Layout>
